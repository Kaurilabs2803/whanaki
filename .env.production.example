# ── Whānaki Production Environment Template ───────────────────────────────────
# Domain: whanaki.kaurilabs.kiwi
#
# HOW TO USE:
#   1. Copy this file to .env on your production server:
#      cp .env.production.example .env
#   2. Replace every placeholder below with your real secrets.
#   3. Save the file and start the app.
#
# DO NOT commit .env to GitHub.

# ── Clerk Auth ────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── RAGFlow ───────────────────────────────────────────────────────────────────
# Generate a random key: openssl rand -hex 24
RAGFLOW_API_KEY=
RAGFLOW_HOST=http://ragflow:9380

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Generate a random password: openssl rand -hex 16
ELASTIC_PASSWORD=

# ── Ollama ────────────────────────────────────────────────────────────────────
# Option A — Ollama on the same droplet (simplest for beginners):
OLLAMA_HOST=http://172.17.0.1:11434
#
# Option B — Separate Ollama droplet (use its private VPC IP):
# OLLAMA_HOST=http://10.10.0.2:11434

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DOMAIN=whanaki.kaurilabs.kiwi
APP_URL=https://whanaki.kaurilabs.kiwi
LOG_LEVEL=info
# Generate with: openssl rand -hex 32
SECRET_KEY=
ALLOWED_ORIGINS=https://whanaki.kaurilabs.kiwi

# ── Database ──────────────────────────────────────────────────────────────────
# DigitalOcean Managed PostgreSQL connection string.
# Must use the +asyncpg driver and ?ssl=require
DATABASE_URL=postgresql+asyncpg://doadmin:PASSWORD@db-host:25060/defaultdb?ssl=require

# ── Valkey (Redis-compatible) ─────────────────────────────────────────────────
# DigitalOcean Managed Valkey connection string.
# If DigitalOcean gives you a valkeys:// URL, change it to rediss:// here.
REDIS_URL=rediss://default:PASSWORD@valkey-host:25061

# ── Next.js (baked into the frontend Docker image at build time) ──────────────
NEXT_PUBLIC_API_URL=https://api.whanaki.kaurilabs.kiwi
NEXT_PUBLIC_APP_URL=https://whanaki.kaurilabs.kiwi
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
